# Copy to .env and fill in.
#
# macOS  : scripts/install-mac.sh creates this file for you and fills in the LAN IP.
# Windows: scripts/install-windows.cmd does the same.

# LiveKit credentials (any random strings; must match livekit.yaml)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=please-change-me-to-32-bytes-of-randomness

# LAN IP of the host running everything.
#   macOS   : ipconfig getifaddr en0
#   Windows : (Get-NetIPAddress -AddressFamily IPv4).IPAddress
# This must be reachable from listener devices on the event network.
LIVEKIT_NODE_IP=192.168.1.10

# Public hostname/IP listeners type into their browser (usually same as NODE_IP).
PUBLIC_HOST=192.168.1.10

# Backend port (Caddy proxies /api/* here).
BACKEND_PORT=3000

# Initial seed for the language list (only used on the first boot, after
# which the languages live in backend/data/languages.json and are managed
# from the admin UI). Comma-separated language codes.
LANGUAGES=en,fr,es

# Admin password — protects /admin.html and /api/admin/* (events, codes,
# languages, backgrounds).
ADMIN_PASSWORD=change-me-admin

# Optional: human-readable display names for the seeded languages (JSON map).
# Falls back to the code if absent.
LANGUAGE_NAMES='{"en":"English","fr":"Français","es":"Español"}'

# Optional: flag emojis (JSON map). Falls back to a built-in default per
# ISO 639-1 code if absent. Override here for multi-flag entries like
# "en":"🇬🇧🇺🇸" or non-default mappings.
# LANGUAGE_FLAGS='{"en":"🇬🇧🇺🇸"}'

# Optional: seed the AI translation settings on first boot. After that they
# live in backend/data/ai-config.json and are managed from the admin "AI
# settings" panel. The OpenRouter key powers automatic translation and stays
# server-side.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini
