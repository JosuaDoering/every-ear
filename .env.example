# Copy to .env and fill in.

# LiveKit credentials (any random strings; must match livekit.yaml)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=please-change-me-to-32-bytes-of-randomness

# LAN IP of the MacBook hosting everything. Run: ipconfig getifaddr en0
# This must be reachable from listener devices on the event network.
LIVEKIT_NODE_IP=192.168.1.10

# Public hostname/IP listeners type into their browser (usually same as NODE_IP).
PUBLIC_HOST=192.168.1.10

# Backend port (Caddy proxies /api/* here).
BACKEND_PORT=3000

# Comma-separated language codes. One LiveKit room per language.
LANGUAGES=en,fr,es

# Admin password — protects /admin.html and /api/admin/* (codes, background).
ADMIN_PASSWORD=change-me-admin

# Optional: human-readable display names (JSON map). Falls back to code if absent.
LANGUAGE_NAMES='{"en":"English","fr":"Français","es":"Español"}'

# Optional: flag emojis (JSON map). Falls back to a built-in default per
# ISO 639-1 code if absent. Override here for multi-flag entries like
# "en":"🇬🇧🇺🇸" or non-default mappings.
# LANGUAGE_FLAGS='{"en":"🇬🇧🇺🇸"}'
