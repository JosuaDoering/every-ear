{
  "name": "every-ear-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Every Ear desktop wrapper (Electron) for macOS and Windows.",
  "main": "build/main.js",
  "scripts": {
    "build:tsc": "tsc -p tsconfig.json",
    "build:renderer": "esbuild renderer/settings.ts --bundle --outfile=build/renderer/settings.js --format=esm --target=es2022 --platform=browser",
    "build:assets": "node scripts/copy-renderer-assets.mjs",
    "build": "npm run build:tsc && npm run build:renderer && npm run build:assets",
    "dev": "npm run build && electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "acme-client": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  },
  "allowScripts": {
    "electron@41.5.0": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.0": true
  }
}
